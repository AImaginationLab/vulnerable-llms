FROM python:3.9-slim

WORKDIR /app

# Install Node.js and development tools
RUN apt-get update && apt-get install -y \
    curl \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Copy and install Python requirements
COPY ./requirements.txt .
RUN pip install -r requirements.txt
COPY ./backend/ ./backend/
RUN python backend/scripts/precompute_common_word_embeddings.py || echo "⚠️ Precompute cache step failed"
RUN pip install watchdog

# Copy package files only (for dependency caching)
COPY ./frontend/package*.json ./frontend/

# Install frontend dependencies
WORKDIR /app/frontend
RUN npm install

WORKDIR /app

# Set environment variables
ENV PYTHONPATH=/app
ENV ENVIRONMENT=development
ENV NODE_ENV=development

# Expose ports
EXPOSE 5000 3000

# Start both dev servers
CMD sh -c "cd /app/frontend && npm run dev -- --host 0.0.0.0 --port 3000 & cd /app/backend && python dev_server.py & wait"
